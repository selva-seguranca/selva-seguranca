DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=selva_seguranca
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_SSLMODE=
DATABASE_URL=
DB_EMULATE_PREPARES=
DB_DEBUG_MESSAGE=
APP_URL=http://localhost:8000
APP_ENV=development
CHECKLIST_STORAGE_DRIVER=local
CHECKLIST_MAX_FILE_SIZE_MB=10
# For Vercel, prefer DATABASE_URL with the Supabase transaction pooler and set DB_EMULATE_PREPARES=true
# If using split vars on Vercel with the transaction pooler, copy the exact DB host, username and password from Supabase Connect
# For Supavisor/Pooler, the username may look like postgres.<project_ref>, not just postgres
# If using split vars on Vercel with the transaction pooler, set DB_PORT=6543 and DB_EMULATE_PREPARES=true
# Do not use db.<project-ref>.supabase.co:6543 on Vercel. That host is the direct database host and is IPv6-only.
# For Vercel, set CHECKLIST_STORAGE_DRIVER=supabase and CHECKLIST_MAX_FILE_SIZE_MB=4
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_STORAGE_BUCKET=checklists
SUPABASE_STORAGE_DIRECTORY=checklists
SUPABASE_STORAGE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_PUBLIC_URL=
# For Supabase Postgres, set DB_SSLMODE=require in production
SUPABASE_TOKEN=your-supabase-access-token
JWT_SECRET=super_secret_jwt_key_for_selva_seguranca
