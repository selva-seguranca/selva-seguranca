# Local development only
# This file is for your machine. Do not copy these DB_* values to Vercel.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=selva_seguranca
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_SSLMODE=

# Optional unified connection string
DATABASE_URL=
DB_EMULATE_PREPARES=
DB_DEBUG_MESSAGE=

APP_URL=http://localhost:8000
APP_ENV=development
APP_DEBUG=false

CHECKLIST_STORAGE_DRIVER=local
CHECKLIST_MAX_FILE_SIZE_MB=10

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_STORAGE_BUCKET=checklists
SUPABASE_COLLABORATORS_BUCKET=colaboradores
SUPABASE_STORAGE_DIRECTORY=checklists
SUPABASE_STORAGE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_PUBLIC_URL=
JWT_SECRET=generate-a-long-random-secret

# Vercel production uses DATABASE_URL from the Supabase Transaction Pooler.
# See .env.vercel.example for the exact variables to create in Vercel.
